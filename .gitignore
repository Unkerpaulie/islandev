# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# --- Django ---
db.sqlite3
db.sqlite3-journal
local_settings.py

# --- Virtualenvs ---
.venv/
venv/
env/

# --- Static / media (runtime artifacts, live in <islandev_root>/) ---
# Note: these dirs live OUTSIDE the repo. Listed here as a safety net only.
/staticfiles/
/media/

# Compiled Tailwind output. Regenerated by the Tailwind CLI on demand.
# We keep static/css/ ignored EXCEPT for the placeholder so the dev server
# does not 404 before the first build.
static/css/*
!static/css/.gitkeep

# --- Tailwind standalone CLI binary (if dropped next to the project) ---
tailwindcss
tailwindcss.exe

# --- Secrets ---
# .env lives at <islandev_root>/.env, outside the repo. Safety net only.
.env
.env.local

# --- IDE / OS ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Test / coverage ---
.coverage
htmlcov/
.pytest_cache/
