# ----------------------------------------------------------------------------
# Documented template for the .env file that lives at <islandev_root>/.env.
# Copy this file to <islandev_root>/.env and fill in real values.
# Never commit the populated .env. This template is the authoritative reference
# for every environment variable the application reads.
# ----------------------------------------------------------------------------

# Which settings module Django (and Gunicorn, in prod) loads.
# Dev:  islandev.settings.dev
# Prod: islandev.settings.prod
DJANGO_SETTINGS_MODULE=islandev.settings.dev

# Human-readable environment label used by scripts for conditional logic.
DJANGO_ENV=dev

# --- Django core ---
DEBUG=True
SECRET_KEY=replace-me-with-a-long-random-string
# Comma-separated. Include the production domain(s) in prod.
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---
# Dev uses SQLite by default (configured in settings/dev.py).
# Prod reads DATABASE_URL via django-environ's env.db() parser, e.g.
#   postgres://user:pass@host:5432/dbname
DATABASE_URL=

# --- Security flags (prod only) ---
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# --- Email (Resend) ---
# Obtain your API key from https://resend.com/api-keys
# Leave blank in dev to disable email sending gracefully (no errors).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The "From" address used for outgoing notifications. Must be a verified
# Resend domain. Format: Display Name <address@yourdomain.com>
RESEND_FROM_EMAIL=Islan.DEV <hello@islan.dev>
# Where form submission notifications are delivered (your inbox).
CONTACT_NOTIFICATION_EMAIL=hello@islan.dev

# --- Infrastructure ---
# Name of the systemd service Gunicorn runs under. Used by the deploy scripts
# to issue `systemctl restart $GUNICORN_SERVICE_NAME`.
GUNICORN_SERVICE_NAME=islandev
